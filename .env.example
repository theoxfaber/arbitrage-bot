# Database Configuration
# Automatically injected by docker-compose for PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/arbitrage

# Authentication
# Secret used by the JWT Token Middleware (Must be changed in prod)
JWT_SECRET_KEY=super_secret_for_dev_only
JWT_ALGORITHM=HS256

# ML / Algorithm Limits
# Only execute and log trades if the Scikit-learn Classifier confidence exceeds this.
MIN_CONFIDENCE=0.85

# Exchange API Keys (Needed for Real Trading only, Paper-Trading uses public orderbooks)
BINANCE_API_KEY=your_binance_api_key_here
BYBIT_API_KEY=your_bybit_api_key_here
